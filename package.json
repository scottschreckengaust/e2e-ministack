{
  "name": "e2e-ministack",
  "version": "0.9.0",
  "private": true,
  "license": "MIT",
  "packageManager": "npm@11.13.0",
  "engines": {
    "node": ">=24.17.0 <25"
  },
  "bin": {
    "e2e-ministack": "bin/app.js"
  },
  "scripts": {
    "build": "tsc && tsc -p tsconfig.scripts.json",
    "watch": "tsc -w",
    "synth": "cdk synth",
    "bootstrap": "cdk bootstrap aws://000000000000/us-east-1",
    "deploy": "cdk deploy --require-approval never",
    "destroy": "cdk destroy --force",
    "lint": "eslint .",
    "lint:md": "markdownlint-cli2",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:mcp-parity": "scripts/check-mcp-parity.sh",
    "test": "npm run test:unit",
    "test:unit": "JEST_TIER=unit jest --coverage",
    "test:integration": "JEST_TIER=integration jest --runInBand",
    "test:e2e": "JEST_TIER=e2e jest",
    "test:mutation": "JEST_TIER=unit stryker run",
    "test:fuzz-regression": "jest --config jest.fuzz.config.js",
    "test:integ-snapshot": "scripts/run-integ-snapshot.sh",
    "test:integ-snapshot:update": "scripts/run-integ-snapshot-update.sh",
    "fuzz": "mkdir -p .fuzz-corpus && jazzer fuzz/handler.fuzz .fuzz-corpus --sync=false -- -max_total_time=60"
  },
  "devDependencies": {
    "@aws-cdk/integ-runner": "2.202.1",
    "@aws-cdk/integ-tests-alpha": "2.260.0-alpha.0",
    "@eslint/js": "^10.0.1",
    "@fast-check/jest": "^2.2.0",
    "@jazzer.js/core": "^4.0.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/jest-runner": "^9.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.2",
    "@types/spdx-satisfies": "^6.0.0",
    "ajv": "^6.15.0",
    "aws-cdk": "2.1128.0",
    "cdk-nag": "^3.0.1",
    "eslint": "^10.5.0",
    "fast-check": "^4.8.0",
    "jest": "^30.4.2",
    "jest-junit": "^17.0.0",
    "markdownlint-cli2": "^0.22.1",
    "prettier": "^3.8.4",
    "smol-toml": "^1.6.1",
    "spdx-satisfies": "^6.0.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.1"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1072.0",
    "@aws-sdk/client-lambda": "^3.1072.0",
    "@aws-sdk/client-s3": "^3.1072.0",
    "aws-cdk-lib": "2.260.0",
    "constructs": "^10.6.0"
  },
  "overrides": {
    "js-yaml": "^4.2.0",
    "markdown-it": "^14.2.0",
    "qs": "^6.15.2"
  }
}
