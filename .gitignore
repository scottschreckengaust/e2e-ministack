# Dependencies
node_modules/

# Local MCP auth — never commit a real GitHub personal access token. The
# "github" MCP server in .mcp.json reads ${GITHUB_PERSONAL_ACCESS_TOKEN} from
# the launch env; supply it from one of these gitignored, per-developer files
# (or your shell), NOT from a committed file:
#   - .env                       — copy from .env.example (shell / --env-file)
#   - .claude/settings.local.json — Claude Code's local-only settings override
.env
.claude/settings.local.json

# Isolated git worktrees — never committed. Claude Code's native tooling uses
# .claude/worktrees/; the generic vendor-neutral location is .worktrees/.
.claude/worktrees/
.worktrees/

# CDK
cdk.out/
# Compiled TS output (sources are .ts; emit is transient). Scoped to the
# compiled locations so hand-written declarations like lambda/index.d.ts stay
# tracked.
bin/*.js
bin/*.d.ts
lib/*.js
lib/*.d.ts
test/**/*.js
test/**/*.d.ts
# services/ (MiniStack compat harness, #135): .ts sources compile in place; the
# committed artifacts here are hand-written .json/.schema.json/.md, not emit.
services/**/*.js
services/**/*.d.ts

# threat-composer-ai generated workflow output (the curated model lives in
# threat-model.tc.json at the repo root, not here)
.threat-composer/

# Stryker mutation testing (reports + incremental cache are generated; the
# cache is restored/saved via actions/cache in CI, never committed)
.stryker-tmp/
reports/

# jazzer.js fuzzing: the exploratory scheduled job's corpus is cached in CI (not
# committed); crash inputs are generated artifacts. (The PR-gating regression
# tier's seed corpus is committed under fuzz/corpus/ and IS tracked.)
.fuzz-corpus/
crash-*

# CI scan reports / outcome files (generated, uploaded as artifacts in CI)
*.sarif
*.outcome
cfn-lint.txt
# Trivy human-readable table reports (SARIF/outcome already covered above)
trivy-fs.txt
trivy-image.txt
npm-audit.json
sbom.cdx.json
# CI-downloaded scanner binaries
/gitleaks
/osv-scanner
gitleaks.tar.gz
ministack.log

# Logs / OS
*.log
.DS_Store
.agents/skills/*-workspace/
