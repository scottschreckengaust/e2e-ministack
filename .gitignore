# Dependencies
node_modules/

# Claude Code isolated worktrees (created by EnterWorktree; never committed)
.claude/worktrees/

# CDK
cdk.out/
# Compiled TS output (sources are .ts; emit is transient). Scoped to the
# compiled locations so hand-written declarations like lambda/index.d.ts stay
# tracked.
bin/*.js
bin/*.d.ts
lib/*.js
lib/*.d.ts
test/**/*.js
test/**/*.d.ts

# threat-composer-ai generated workflow output (the curated model lives in
# threat-model.tc.json at the repo root, not here)
.threat-composer/

# Stryker mutation testing (reports + incremental cache are generated; the
# cache is restored/saved via actions/cache in CI, never committed)
.stryker-tmp/
reports/

# jazzer.js fuzzing: corpus is cached in CI (not committed); crash inputs are
# generated artifacts.
.fuzz-corpus/
crash-*

# CI scan reports / outcome files (generated, uploaded as artifacts in CI)
*.sarif
*.outcome
cfn-lint.txt
npm-audit.json
sbom.cdx.json
# CI-downloaded scanner binaries
/gitleaks
/osv-scanner
gitleaks.tar.gz
ministack.log

# Logs / OS
*.log
.DS_Store
.agents/skills/*-workspace/
