{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "helpers:pinGitHubActionDigests",
    ":semanticCommits",
    ":dependencyDashboard"
  ],
  "timezone": "Etc/UTC",
  "schedule": ["before 6am on monday"],
  "labels": ["dependencies"],
  "semanticCommitType": "deps",
  "rangeStrategy": "pin",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 6am on monday"]
  },
  "packageRules": [
    {
      "description": "Group all dev dependencies into a single PR.",
      "matchDepTypes": ["devDependencies"],
      "groupName": "dev dependencies"
    },
    {
      "description": "Group GitHub Actions digest pins together.",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "description": "Pin the MiniStack image by digest (the repo pins it by sha256).",
      "matchManagers": ["dockerfile", "docker-compose", "regex"],
      "pinDigests": true
    },
    {
      "description": "aws-cdk / aws-cdk-lib are tightly version-coupled and Node-runtime-gated; review their bumps individually rather than auto-grouping.",
      "matchPackageNames": ["aws-cdk", "aws-cdk-lib"],
      "groupName": null
    }
  ],
  "customManagers": [
    {
      "description": "Keep the MiniStack image digest in ci.yml managed by Renovate.",
      "customType": "regex",
      "managerFilePatterns": ["/^\\.github/workflows/ci\\.yml$/"],
      "matchStrings": [
        "(?<depName>ministackorg/ministack):(?<currentValue>[^@\\s]+)@(?<currentDigest>sha256:[a-f0-9]+)"
      ],
      "datasourceTemplate": "docker"
    }
  ]
}
