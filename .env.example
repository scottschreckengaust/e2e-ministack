# Copy this file to .env and fill in your private developer token:
#   cp .env.example .env
# .env is gitignored — never commit a real token.
#
# The "github" MCP server in .mcp.json is the remote HTTP server and reads
# this token from Claude Code's LAUNCH ENVIRONMENT via ${GITHUB_PERSONAL_ACCESS_TOKEN}
# (Claude does NOT auto-load .env). Provide it via ONE gitignored location:
#   - this .env, exported before launch:  set -a; . ./.env; set +a
#   - ~/.claude/settings.json  "env": { "GITHUB_PERSONAL_ACCESS_TOKEN": "..." }
#   - .claude/settings.local.json (project-local; same "env" shape)
# All three are gitignored — see .gitignore. The local-Docker fallback in
# docs/MCP.md instead reads this .env directly via `--env-file .env`.

# GitHub fine-grained / classic personal access token used by the GitHub MCP
# server. Scope it to the minimum needed (repo + read:org is typical).
GITHUB_PERSONAL_ACCESS_TOKEN=your_token_here

# NOTE: read-only mode and toolset scoping for the REMOTE server are set as
# HTTP headers in .mcp.json (X-MCP-Readonly / X-MCP-Toolsets), not here. This
# repo's PoC ships X-MCP-Toolsets: all. The vars below apply ONLY to the
# local-Docker fallback (github-mcp-server reads them from --env-file .env).

# Read-only mode for the local-Docker fallback. 1 forbids all writes.
GITHUB_READ_ONLY=0

# Toolset scoping for the local-Docker fallback (comma-separated), e.g.
# "repos,issues,pull_requests" to shrink the surface area.
GITHUB_TOOLSETS=all
